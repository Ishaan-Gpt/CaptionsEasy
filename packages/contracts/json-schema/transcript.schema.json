{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motionai.dev/schemas/transcript.schema.json",
  "title": "Transcript",
  "description": "Speech recognition output. Never contains styling. Source: contracts/json-schemas.md",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "language", "duration_ms", "words"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "language": { "type": "string" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "words": {
      "type": "array",
      "items": { "$ref": "#/$defs/Word" }
    }
  },
  "$defs": {
    "Word": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "start_ms", "end_ms", "confidence"],
      "properties": {
        "text": { "type": "string" },
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
