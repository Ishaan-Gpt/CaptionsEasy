{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"]
}
