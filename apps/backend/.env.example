# --- App ---
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# --- Database ---
# Used by the FastAPI app at runtime (async driver).
DATABASE_URL_ASYNC=postgresql+asyncpg://user:password@localhost:5432/motionai
# Used by Alembic migrations (sync driver). See alembic/env.py.
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/motionai

# --- Auth (Supabase) ---
SUPABASE_JWT_SECRET=replace-me
SUPABASE_JWT_ALGORITHM=HS256

# --- Storage (Supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=videos

# --- Upload limits ---
MAX_UPLOAD_SIZE_BYTES=524288000

# --- Background processing (Celery + Redis) ---
REDIS_URL=redis://localhost:6379/0
JOB_MAX_RETRIES=2
JOB_RETRY_COUNTDOWN_SECONDS=5
JOB_LOCK_TTL_SECONDS=900
JOB_PROGRESS_TTL_SECONDS=3600
JOB_STAGE_DURATION_SECONDS=1.0

# --- AI provider selection ("dummy" or "groq"; render plan has no real provider yet) ---
SPEECH_PROVIDER_NAME=dummy
CREATIVE_PROVIDER_NAME=dummy
CAPTION_PROVIDER_NAME=dummy
RENDER_PLAN_PROVIDER_NAME=dummy

# --- Groq AI (speech provider, OpenAI-Whisper-compatible) ---
GROQ_API_KEY=replace-me
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_SPEECH_MODEL=whisper-large-v3
GROQ_TIMEOUT_SECONDS=120
GROQ_COST_PER_SECOND_USD=0.0001

# --- Groq AI (creative/caption providers, chat-completions JSON mode) ---
GROQ_CREATIVE_MODEL=llama-3.3-70b-versatile
GROQ_CAPTION_MODEL=llama-3.3-70b-versatile
GROQ_CREATIVE_COST_INPUT_USD=0.00000059
GROQ_CREATIVE_COST_OUTPUT_USD=0.00000079
GROQ_CAPTION_COST_INPUT_USD=0.00000059
GROQ_CAPTION_COST_OUTPUT_USD=0.00000079
